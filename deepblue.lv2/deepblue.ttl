@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix doap:   <http://usefulinc.com/ns/doap#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix units:  <http://lv2plug.in/ns/extensions/units#> .
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

<https://github.com/pilali/deepblue>
    a lv2:Plugin, lv2:EffectPlugin ;

    doap:name    "Deepblue" ;
    doap:license <https://spdx.org/licenses/GPL-3.0-or-later.html> ;

    lv2:optionalFeature lv2:hardRTCapable ;

    lv2:port

    # ── Audio I/O ────────────────────────────────────────────────────────
    [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "audio_in" ;
        lv2:name   "Audio In"
    ] ,
    [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 1 ;
        lv2:symbol "audio_out" ;
        lv2:name   "Audio Out"
    ] ,

    # ── Controls ─────────────────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   2 ;
        lv2:symbol  "depth" ;
        lv2:name    "Depth" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.5
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   3 ;
        lv2:symbol  "tone" ;
        lv2:name    "Tone" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.5
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   4 ;
        lv2:symbol  "wobble" ;
        lv2:name    "Wobble" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.35
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   5 ;
        lv2:symbol  "wobble_rate" ;
        lv2:name    "Wobble Rate" ;
        lv2:minimum 0.05 ;
        lv2:maximum 2.0 ;
        lv2:default 0.3 ;
        units:unit  units:hz ;
        lv2:portProperty pprops:logarithmic
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   6 ;
        lv2:symbol  "dispersion" ;
        lv2:name    "Dispersion" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.4
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   7 ;
        lv2:symbol  "mix" ;
        lv2:name    "Mix" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.6
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   8 ;
        lv2:symbol  "level" ;
        lv2:name    "Level" ;
        lv2:minimum 0.0 ;
        lv2:maximum 2.0 ;
        lv2:default 1.0
    ] ,

    # ── Optional right-side ports ────────────────────────────────────────
    # Connected by the host ⇒ stereo. Left output unconnected ⇒ the plugin
    # runs as a plain mono effect. Right input unconnected (but right output
    # connected) ⇒ mono-in, decorrelated-stereo-out.
    [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 9 ;
        lv2:symbol "audio_in_r" ;
        lv2:name   "Audio In R" ;
        lv2:portProperty lv2:connectionOptional
    ] ,
    [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 10 ;
        lv2:symbol "audio_out_r" ;
        lv2:name   "Audio Out R" ;
        lv2:portProperty lv2:connectionOptional
    ] ,

    # ── Bubble layer (step 4) ────────────────────────────────────────────
    # Appended past the optional audio ports so the indices above stay stable.
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   11 ;
        lv2:symbol  "bubbles" ;
        lv2:name    "Bubbles" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.0
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   12 ;
        lv2:symbol  "bubble_size" ;
        lv2:name    "Bubble Size" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.4
    ] ,

    # ── Loss of localisation (step 3) ────────────────────────────────────
    # Cross-channel: only audible on the stereo path.
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   13 ;
        lv2:symbol  "immersion" ;
        lv2:name    "Immersion" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.4
    ] .
