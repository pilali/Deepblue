@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/pilali/deepblue>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate    <modgui/icon-deepblue.html> ;
        modgui:stylesheet      <modgui/stylesheet-deepblue.css> ;
        modgui:javascript      <modgui/script-deepblue.js> ;
        modgui:screenshot      <modgui/screenshot-deepblue.png> ;
        modgui:thumbnail       <modgui/thumbnail-deepblue.png> ;
        modgui:brand           "Pilal" ;
        modgui:label           "Deepblue" ;

        # Ports surfaced to the host (parameter list / automation). The icon
        # template binds each widget directly by lv2:symbol.
        modgui:port [
            lv2:index 2 ;  lv2:symbol "depth" ;        lv2:name "Depth" ;
        ] , [
            lv2:index 3 ;  lv2:symbol "tone" ;         lv2:name "Tone" ;
        ] , [
            lv2:index 4 ;  lv2:symbol "wobble" ;       lv2:name "Wobble" ;
        ] , [
            lv2:index 5 ;  lv2:symbol "wobble_rate" ;  lv2:name "Wobble Rate" ;
        ] , [
            lv2:index 6 ;  lv2:symbol "dispersion" ;   lv2:name "Dispersion" ;
        ] , [
            lv2:index 7 ;  lv2:symbol "mix" ;          lv2:name "Mix" ;
        ] , [
            lv2:index 8 ;  lv2:symbol "level" ;        lv2:name "Level" ;
        ] , [
            lv2:index 9 ;  lv2:symbol "bubbles" ;      lv2:name "Bubbles" ;
        ] , [
            lv2:index 10 ; lv2:symbol "bubble_size" ;  lv2:name "Bubble Size" ;
        ] , [
            lv2:index 11 ; lv2:symbol "immersion" ;    lv2:name "Immersion" ;
        ] , [
            lv2:index 12 ; lv2:symbol "reverb" ;       lv2:name "Reverb" ;
        ] , [
            lv2:index 13 ; lv2:symbol "reverb_size" ;  lv2:name "Reverb Size" ;
        ] ;
    ] .
