@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<DeepCurrent.ttl>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/pilali/deepblue> ;
	rdfs:label "Deep Current" ;
	lv2:port [
		lv2:symbol "bubble_size" ;
		pset:value 0.87
	] , [
		lv2:symbol "bubbles" ;
		pset:value 0.9
	] , [
		lv2:symbol "depth" ;
		pset:value 0.82
	] , [
		lv2:symbol "dispersion" ;
		pset:value 1.0
	] , [
		lv2:symbol "immersion" ;
		pset:value 0.73
	] , [
		lv2:symbol "level" ;
		pset:value 1.2
	] , [
		lv2:symbol "mix" ;
		pset:value 1.0
	] , [
		lv2:symbol "reverb" ;
		pset:value 0.86
	] , [
		lv2:symbol "reverb_size" ;
		pset:value 0.74
	] , [
		lv2:symbol "tone" ;
		pset:value 0.58
	] , [
		lv2:symbol "wobble" ;
		pset:value 0.72
	] , [
		lv2:symbol "wobble_rate" ;
		pset:value 0.51
	] .
