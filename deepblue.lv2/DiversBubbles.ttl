@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<DiversBubbles.ttl>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/pilali/deepblue> ;
	rdfs:label "Diver's Bubbles" ;
	lv2:port [
		lv2:symbol "bubble_size" ;
		pset:value 0.71
	] , [
		lv2:symbol "bubbles" ;
		pset:value 0.68
	] , [
		lv2:symbol "depth" ;
		pset:value 0.45
	] , [
		lv2:symbol "dispersion" ;
		pset:value 0.3
	] , [
		lv2:symbol "immersion" ;
		pset:value 0.4
	] , [
		lv2:symbol "level" ;
		pset:value 1.2
	] , [
		lv2:symbol "mix" ;
		pset:value 0.4
	] , [
		lv2:symbol "reverb" ;
		pset:value 0.35
	] , [
		lv2:symbol "reverb_size" ;
		pset:value 0.5
	] , [
		lv2:symbol "tone" ;
		pset:value 0.55
	] , [
		lv2:symbol "wobble" ;
		pset:value 0.63
	] , [
		lv2:symbol "wobble_rate" ;
		pset:value 0.5
	] .
